# ============================================================
# RhôneRisk Policy Analyzer — Environment Variables
# ============================================================
# Copy this file to .env for local development.
# On Railway, set these as service variables.
# ============================================================

# --- Required ---

# Anthropic API key (for Claude-based policy analysis)
ANTHROPIC_API_KEY=sk-ant-xxx

# --- Supabase (for persistent storage) ---
# If not set, falls back to local SQLite (data/users.db)

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (preferred — bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase anon key (fallback if service role key not set)
SUPABASE_KEY=eyJ...

# --- JWT Authentication ---

# JWT signing secret (if empty, auto-generated and persisted to data/.jwt_secret)
# IMPORTANT: Set this on Railway so tokens survive redeployments
JWT_SECRET=

# --- Cloudflare R2 (optional — for cloud report storage) ---

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=rhone-analyzer

# --- Server ---

# Port (Railway sets this automatically)
PORT=8000

# Log level
LOG_LEVEL=INFO

# Claude model and settings
CLAUDE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_MAX_TOKENS=16384
CLAUDE_THINKING_BUDGET=8192
MAX_UPLOAD_SIZE_MB=50
TEMP_DIR=/tmp/rhone-analyzer
